# Sao chép thành `.env`, điền giá trị, khởi động lại server.

# Cùng Web client ID như VITE_GOOGLE_CLIENT_ID trên frontend (verify ID token GIS).
GOOGLE_CLIENT_ID=

# Đã có sẵn trong project — không xoá.
# JWT_SECRET=

# Mã mời để đăng ký tài khoản role `admin` (API /api/auth/register). Để trống = không cho đăng ký admin qua API.
ADMIN_INVITE_CODE=
